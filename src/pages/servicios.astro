---
import Layout from "../layouts/Layout.astro";
import { placeholderImages } from "../data/site";

const services = [
  {
    title: "Visas y permisos",
    description:
      "Análisis de requisitos para visas, permisos de trabajo, autorizaciones temporales y rutas de residencia.",
  },
  {
    title: "Familias y reunificación",
    description:
      "Apoyo para ordenar escenarios familiares, acompañantes, dependientes y documentación de respaldo.",
  },
  {
    title: "Estudio y talento global",
    description:
      "Orientación para estudiantes, profesionales y perfiles calificados que buscan oportunidades internacionales.",
  },
  {
    title: "Empresas y movilidad",
    description:
      "Asistencia a emprendedores y equipos que necesitan trasladarse, contratar talento o expandirse entre países.",
  },
];
---

<Layout
  title="Servicios Migratorios Globales - Cristian Gutierrez"
  description="Servicios de asesoría migratoria global: visas, residencia, permisos de trabajo, estudio, familias y movilidad empresarial."
> 
  <div class="page-shell">
    <header class="hero" id="servicios">
      <div class="hero-copy">
        <span class="eyebrow">Servicios migratorios</span>
        <h1>Soluciones para procesos migratorios entre países.</h1>
        <p>
          Asesoría especializada para entender opciones, preparar documentos y avanzar con una estrategia clara
          según origen, destino y objetivo migratorio.
        </p> 
        <div class="hero-actions">
          <a class="btn btn-primary" href="/contacto">Consultar</a>
          <a class="btn btn-secondary" href="/sobre-nosotros">Sobre Mi</a>
        </div>
      </div>
      <div class="hero-visual">
        <img
          src={placeholderImages.services}
          alt="Placeholder de servicios de migración global"
          loading="eager"
          width="840"
          height="620"
        />
      </div>
    </header>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Categorias de servicios</p>
        <h2>Una ruta ordenada para tu situación migratoria.</h2>
      </div>
      <div class="cards-grid">
        {services.map((service) => (
          <article class="service-card">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-light section-split">
      <div class="about-copy">
        <p class="eyebrow">Por que elegirnos</p>
        <h2>Experiencia, criterio y comunicación clara durante el proceso.</h2>
        <p>
          Simplifico trámites complejos y ayudo a evitar errores costosos. Cada caso recibe atención
          personalizada, revisión de requisitos y seguimiento integral.
        </p> 
        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <h3>Diagnóstico rápido</h3>
            <p>Evaluación inicial de opciones, requisitos y posibles puntos de riesgo.</p>
          </div>
          <div class="feature-card">
            <h3>Seguimiento total</h3>
            <p>Gestión ordenada del avance y comunicación constante en cada etapa.</p>
          </div> 
        </div>
      </div>
      <div class="about-image">
        <img
          src={placeholderImages.value}
          alt="Placeholder de estrategia migratoria"
          loading="lazy"
          width="720"
          height="540"
        />
      </div>
    </section>

    <section class="section section-contact">
      <div class="contact-card">
        <span class="eyebrow">Comencemos</span>
        <h2>Listo para ordenar tu situación migratoria?</h2>
        <p>Agenda una consulta inicial y recibe un plan de acción claro para tu caso.</p>
        <div class="contact-actions">
          <a class="btn btn-primary" href="/contacto">Agendar consulta</a>
          <a class="btn btn-secondary" href="/sobre-nosotros">Conocer más</a>
        </div> 
      </div>
    </section>
  </div>
</Layout>
