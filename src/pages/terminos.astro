---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { siteImages } from "../data/site";
---

<Layout
  title="Términos y condiciones | Cristian Gutiérrez"
  description="Términos y condiciones del uso del sitio y de los servicios de asesoría migratoria global de Cristian Gutiérrez"
  image={siteImages.terms}
  imageAlt="Documentos organizados sobre un escritorio profesional"
  preloadImage={{
    src: siteImages.terms,
    sizes: "(min-width: 1024px) 480px, calc(100vw - 32px)",
  }}
>
  <div class="page-shell">
    <section class="section section-split">
      <div class="about-copy">
        <span class="eyebrow">Términos</span>
        <h1>Condiciones de uso para el sitio web y los servicios</h1>
        <p>
          Lee los términos que regulan el uso de esta página y la relación con los servicios de asesoría
          migratoria ofrecidos por Cristian Gutiérrez
        </p>
      </div>
      <div class="about-image">
        <ResponsiveImage
          src={siteImages.terms}
          alt="Documentos organizados sobre un escritorio profesional"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="720"
          height="540"
          sizes="(min-width: 1024px) 480px, calc(100vw - 32px)"
        />
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Alcance</p>
        <h2>Limitaciones de responsabilidad y uso adecuado</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <span class="feature-icon"><Icon name="document" /></span>
          <h3>Información del sitio</h3>
          <p>El contenido tiene fines informativos y no sustituye asesoramiento personalizado</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="check" /></span>
          <h3>Responsabilidad</h3>
          <p>Las decisiones migratorias deben tomarse tras revisar el caso y la normativa aplicable</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="briefcase" /></span>
          <h3>Derechos</h3>
          <p>El contenido del sitio pertenece a Cristian Gutiérrez y se actualiza cuando el servicio o la normativa lo requiere</p>
        </div>
      </div>
    </section>
  </div>
</Layout>
