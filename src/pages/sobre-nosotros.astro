---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import { siteConfig, siteImages } from "../data/site";
---

<Layout
  title="Sobre Mi - Cristian Gutierrez"
  description="Conoce el enfoque de Cristian Gutierrez para brindar asesoria migratoria global con claridad, estrategia y acompanamiento personalizado."
>
  <div class="page-shell">
    <section class="section section-split about-page">
      <div class="about-copy">
        <span class="eyebrow">Mi trayectoria</span>
        <h1>Asesoria migratoria con enfoque global y acompanamiento cercano.</h1>
        <p>
          En Cristian Gutierrez combino criterio legal, vision practica y comunicacion clara para ayudar
          a personas, familias y empresas a estructurar procesos migratorios internacionales.
        </p>
        <p>
          Mi trabajo se centra en comprender cada situacion particular, reducir incertidumbre administrativa
          y guiar el proceso de principio a fin con transparencia.
        </p>
      </div>
      <div class="about-image">
        <img
          src={siteImages.about}
          alt="Saludo profesional como referencia para fotografia de trayectoria"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
        />
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Mi enfoque</p>
        <h2>Claridad, confiabilidad y decisiones mejor informadas.</h2>
      </div>
      <div class="feature-grid feature-grid-2">
        <div class="feature-card">
          <span class="feature-icon"><Icon name="check" /></span>
          <h3>Asesoria transparente</h3>
          <p>Explico cada paso del tramite sin complejidades innecesarias.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="document" /></span>
          <h3>Gestion agil</h3>
          <p>Organizo prioridades, documentos y proximos pasos para evitar friccion.</p>
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Contacto directo</p>
        <h2>Hablemos de tu caso migratorio.</h2>
      </div>
      <form action={`https://formsubmit.co/${siteConfig.email}`} method="POST" class="contact-form">
        <input type="hidden" name="_subject" value="Nuevo mensaje desde sobre-mi" />
        <input type="hidden" name="_captcha" value="false" />

        <label>
          <span>Nombre completo</span>
          <input type="text" name="name" required placeholder="Tu nombre completo" />
        </label>

        <label>
          <span>Correo electronico</span>
          <input type="email" name="email" required placeholder="tucorreo@ejemplo.com" />
        </label>

        <label>
          <span>Mensaje</span>
          <textarea name="message" rows="6" required placeholder="Cuentanos brevemente tu situacion..."></textarea>
        </label>

        <button type="submit" class="btn btn-primary">Enviar mensaje</button>
      </form>
    </section>
  </div>
</Layout>
