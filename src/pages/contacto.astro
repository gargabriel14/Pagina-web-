---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import { siteConfig, siteImages } from "../data/site";
---

<Layout
  title="Contacto - Cristian Gutiérrez"
  description="Contacta a Cristian Gutiérrez para una consulta de asesoría migratoria global sobre visas, residencia, permisos y movilidad internacional"
>
  <div class="page-shell">
    <section class="section section-split contact-page">
      <div class="about-copy">
        <span class="eyebrow">Contacto</span>
        <h1>Consúltame sobre tu situación migratoria internacional</h1>
        <p>
          Completa el formulario o usa los datos de contacto para agendar una consulta sobre visas,
          residencia, permisos y planificación migratoria
        </p>

        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <span class="feature-icon"><Icon name="document" /></span>
            <h3>Correo</h3>
            <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
          </div>
          <div class="feature-card">
            <span class="feature-icon"><Icon name="calendar" /></span>
            <h3>Teléfono</h3>
            <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
          </div>
        </div>
      </div>
      <div class="about-image">
        <img
          src={siteImages.contact}
          alt="Escritorio profesional como referencia para fotografía de contacto online"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
        />
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Formulario</p>
        <h2>Envía tu mensaje y nos pondremos en contacto pronto</h2>
      </div>
      <form action={`https://formsubmit.co/${siteConfig.email}`} method="POST" class="contact-form">
        <input type="hidden" name="_subject" value="Nueva consulta desde pagina-web-orcin.vercel.app" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value={`${siteConfig.url}/contacto`} />

        <label>
          <span>Nombre completo</span>
          <input type="text" name="name" required placeholder="Tu nombre completo" />
        </label>

        <label>
          <span>Correo electrónico</span>
          <input type="email" name="email" required placeholder="tucorreo@ejemplo.com" />
        </label>

        <label>
          <span>Destino o consulta</span>
          <input type="text" name="subject" required placeholder="País, visa o situación a evaluar" />
        </label>

        <label>
          <span>Mensaje</span>
          <textarea name="message" rows="6" required placeholder="Explica brevemente tu situación"></textarea>
        </label>

        <button type="submit" class="btn btn-primary">Enviar mensaje</button>
      </form>
    </section>
  </div>
</Layout>
