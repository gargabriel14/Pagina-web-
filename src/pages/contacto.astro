---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { siteConfig, siteImages } from "../data/site";

const siteUrl = Astro.site ?? new URL(siteConfig.url);
const thankYouUrl = new URL("/gracias/", siteUrl).toString();
---

<Layout
  title="Contacto para asesoría migratoria | Cristian Gutiérrez"
  description="Contacta a Cristian Gutiérrez para evaluar visas, residencia, permisos, reunificación y movilidad internacional con atención online"
  image={siteImages.contact}
  imageAlt="Asesor migratorio disponible para una consulta online internacional"
  preloadImage={{
    src: siteImages.contact,
    sizes: "(min-width: 1024px) 480px, calc(100vw - 32px)",
  }}
>
  <div class="page-shell">
    <section class="section section-split">
      <div class="about-copy">
        <span class="eyebrow">Contacto</span>
        <h1>Comparte tu caso y recibe una primera lectura estratégica</h1>
        <p>
          Para orientarte mejor, comparte tu país de origen, destino, objetivo migratorio y etapa actual del proceso
        </p>

        <h2 class="sr-only">Datos de contacto</h2>
        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <span class="feature-icon"><Icon name="document" /></span>
            <h3>Correo</h3>
            <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
          </div>
          <div class="feature-card">
            <span class="feature-icon"><Icon name="calendar" /></span>
            <h3>Teléfono</h3>
            <p><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></p>
          </div>
        </div>
      </div>
      <div class="about-image">
        <ResponsiveImage
          src={siteImages.contact}
          alt="Asesor migratorio disponible para una consulta online internacional"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="720"
          height="540"
          sizes="(min-width: 1024px) 480px, calc(100vw - 32px)"
        />
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Formulario</p>
        <h2>Mientras más claro sea el contexto, mejor será la primera respuesta</h2>
      </div>
      <form action={`https://formsubmit.co/${siteConfig.email}`} method="POST" accept-charset="UTF-8" class="contact-form">
        <input type="hidden" name="_subject" value="Nueva consulta desde página web" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value={thankYouUrl} />

        <div class="form-grid">
          <label>
            <span>Nombre completo</span>
            <input type="text" name="name" autocomplete="name" required placeholder="Tu nombre completo" />
          </label>

          <label>
            <span>Correo electrónico</span>
            <input type="email" name="email" autocomplete="email" required placeholder="tucorreo@ejemplo.com" />
          </label>

          <label>
            <span>País de origen</span>
            <input type="text" name="origin_country" autocomplete="country-name" required placeholder="Ejemplo: Colombia" />
          </label>

          <label>
            <span>Destino que quieres evaluar</span>
            <input type="text" name="destination_country" required placeholder="Ejemplo: España" />
          </label>
        </div>

        <label>
          <span>Tipo de consulta</span>
          <select name="consultation_type" required>
            <option value="">Selecciona una opción</option>
            <option value="Visa o residencia">Visa o residencia</option>
            <option value="Familia o acompañantes">Familia o acompañantes</option>
            <option value="Trabajo, estudio o talento">Trabajo, estudio o talento</option>
            <option value="Empresa o movilidad de equipo">Empresa o movilidad de equipo</option>
          </select>
        </label>

        <label>
          <span>Mensaje</span>
          <textarea name="message" rows="6" required placeholder="Explica tu objetivo, fecha estimada y cualquier documento o duda importante"></textarea>
        </label>

        <div class="privacy-consent">
          <input id="privacy-consent" type="checkbox" name="privacy_consent" value="Aceptado" required />
          <label for="privacy-consent">Acepto la <a href="/privacidad/">política de privacidad</a> y el uso de mis datos para responder esta consulta</label>
        </div>

        <div class="form-submit-row">
          <button type="submit" class="btn btn-primary" aria-describedby="privacy-note">Enviar mi caso</button>
          <p id="privacy-note">Tu información se usa únicamente para revisar y responder tu consulta</p>
        </div>
      </form>
    </section>
  </div>
</Layout>
