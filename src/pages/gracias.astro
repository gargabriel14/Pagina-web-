---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Consulta recibida | Cristian Gutiérrez"
  description="Confirmación de recepción de una consulta de asesoría migratoria"
  noindex={true}
>
  <div class="page-shell">
    <section class="section response-page">
      <div class="not-found-card">
        <p class="eyebrow">Mensaje recibido</p>
        <h1>Gracias por compartir tu caso</h1>
        <p>La información ya fue enviada y será revisada para preparar una primera respuesta sobre tu situación</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/">Volver al inicio</a>
          <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
