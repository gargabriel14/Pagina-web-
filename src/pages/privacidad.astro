---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import { siteImages } from "../data/site";
---

<Layout
  title="Política de Privacidad - Cristian Gutiérrez"
  description="Política de privacidad sobre el tratamiento de datos personales en consultas de asesoría migratoria global"
>
  <div class="page-shell">
    <section class="section section-split about-page">
      <div class="about-copy">
        <span class="eyebrow">Privacidad</span>
        <h1>Protegemos tu información con cuidado y confidencialidad</h1>
        <p>
          En Cristian Gutiérrez tratamos los datos personales con reserva y los usamos solo para responder
          consultas, preparar diagnósticos y brindar servicios de asesoría migratoria
        </p>
      </div>
      <div class="about-image">
        <img
          src={siteImages.privacy}
          alt="Firma de documentos como referencia para fotografía legal"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
        />
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Compromiso</p>
        <h2>Recopilación, uso y conservación de datos</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <span class="feature-icon"><Icon name="document" /></span>
          <h3>Datos personales</h3>
          <p>Recopilamos únicamente la información necesaria para gestionar consultas y servicios</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="check" /></span>
          <h3>Uso responsable</h3>
          <p>Los datos se utilizan para seguimiento de solicitudes, comunicación y mejora de la atención</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="briefcase" /></span>
          <h3>Seguridad</h3>
          <p>Mantenemos criterios de confidencialidad para preservar la información compartida</p>
        </div>
      </div>
    </section>
  </div>
</Layout>
