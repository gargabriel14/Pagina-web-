---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import {
  audiencePaths,
  consultationDeliverables,
  decisionPoints,
  faqItems,
  processSteps,
  services,
  siteConfig,
  siteImages,
  trustSignals,
} from "../data/site";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Cristian Gutiérrez | Asesoría Migratoria Global"
  description="Asesoría migratoria global para personas, familias y empresas que necesitan claridad, estrategia y acompañamiento antes de iniciar un proceso internacional"
>
  <div class="page-shell">
    <header class="hero hero-conversion" id="inicio">
      <div class="hero-copy">
        <span class="eyebrow">Movilidad internacional con criterio</span>
        <h1>Tu proceso migratorio no empieza con un formulario, empieza con una estrategia</h1>
        <p>
          Cristian Gutiérrez te ayuda a evaluar opciones, ordenar documentos y tomar decisiones migratorias
          con una ruta clara antes de invertir tiempo, dinero y energía
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/contacto/">Evaluar mi ruta migratoria</a>
          <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
        </div>

        <div class="hero-proof" aria-label="Señales de confianza">
          {trustSignals.map((signal) => (
            <div class="hero-stat">
              <strong>{signal.value}</strong>
              <span>{signal.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-visual hero-visual-panel">
        <ResponsiveImage
          src={siteImages.hero}
          alt="Reunión de asesoría migratoria en una oficina profesional"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="840"
          height="620"
          sizes="(min-width: 1024px) 560px, calc(100vw - 32px)"
        />
        <div class="visual-callout">
          <span>Consulta estratégica</span>
          <strong>Origen, destino, objetivo, riesgos y documentos clave</strong>
        </div>
      </div>
    </header>

    <section class="section conversion-band">
      <p>Si estás por aplicar a una visa, mudarte con tu familia o trasladar talento, el primer paso no es llenar formularios</p>
      <strong>El primer paso es saber qué ruta tiene sentido para tu perfil</strong>
    </section>

    <section class="section section-dark" id="servicios">
      <div class="section-header">
        <p class="eyebrow">Servicios migratorios</p>
        <h2>Asesoría para convertir un proceso complejo en una ruta posible</h2>
      </div>
      <div class="cards-grid">
        {services.map((service) => (
          <article class="service-card lift-card">
            <span class="service-icon"><Icon name={service.icon} /></span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-dark decision-section">
      <div class="section-header">
        <p class="eyebrow">Decisiones críticas</p>
        <h2>La consulta está pensada para responder lo que realmente cambia el resultado</h2>
      </div>
      <div class="decision-layout">
        <div class="decision-list">
          {decisionPoints.map((point) => (
            <div class="decision-item">
              <span><Icon name="check" /></span>
              <p>{point}</p>
            </div>
          ))}
        </div>
        <div class="decision-panel">
          <span class="eyebrow">Antes de avanzar</span>
          <h3>Evita comprar tranquilidad falsa</h3>
          <p>
            Un trámite mal elegido puede consumir semanas, dinero y oportunidades, una ruta bien revisada te
            permite avanzar con prioridades y límites claros
          </p>
          <a class="btn btn-primary" href="/contacto/">Revisar mi situación</a>
        </div>
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Qué recibes</p>
        <h2>Sales de la consulta con una ruta accionable, no con dudas nuevas</h2>
      </div>
      <div class="feature-grid">
        {consultationDeliverables.map((item) => (
          <article class="feature-card lift-card">
            <span class="feature-icon"><Icon name={item.icon} /></span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-split">
      <div class="about-copy">
        <p class="eyebrow">Acerca de mí</p>
        <h2>Tu caso no necesita promesas, necesita criterio y una hoja de ruta</h2>
        <p>
          Trabajo con personas, familias y compañías que necesitan avanzar sin perderse entre requisitos,
          tiempos, formularios y cambios de normativa
        </p>

        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <span class="feature-icon"><Icon name="check" /></span>
            <h3>Asesoría práctica</h3>
            <p>Escenarios, riesgos y pasos concretos explicados en lenguaje claro</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon"><Icon name="document" /></span>
            <h3>Documentación ordenada</h3>
            <p>Expedientes consistentes, completos y fáciles de revisar</p>
          </div>
        </div>
      </div>

      <div class="about-image image-reveal">
        <ResponsiveImage
          src={siteImages.advisor}
          alt="Saludo profesional como referencia para fotografía del asesor"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
          sizes="(min-width: 1024px) 480px, calc(100vw - 32px)"
        />
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Elige tu punto de partida</p>
        <h2>Cada perfil necesita una estrategia distinta</h2>
      </div>
      <div class="audience-grid">
        {audiencePaths.map((path) => (
          <article class="audience-card">
            <span class="feature-icon"><Icon name={path.icon} /></span>
            <h3>{path.title}</h3>
            <p>{path.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Método de trabajo</p>
        <h2>Un proceso diseñado para que sepas qué hacer después de cada conversación</h2>
      </div>
      <div class="process-grid process-timeline">
        {processSteps.map((step) => (
          <article class="process-card">
            <span class="step-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2>Respuestas rápidas antes de agendar</h2>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="section section-split section-partners">
      <div class="partners-copy">
        <p class="eyebrow">Red internacional</p>
        <h2>Cuando el caso lo requiere, se coordina con especialistas por destino</h2>
        <p>
          Esta estructura permite integrar abogados locales, traductores, consultores fiscales y aliados de
          movilidad cuando el proyecto migratorio necesita soporte adicional
        </p>
      </div>
      <div class="logo-grid">
        <div class="logo-item">Abogados locales</div>
        <div class="logo-item">Traductores</div>
        <div class="logo-item">Empresas</div>
        <div class="logo-item">Instituciones</div>
      </div>
    </section>

    <section class="section section-contact" id="contacto">
      <div class="contact-card contact-card-wide">
        <span class="eyebrow">Siguiente paso</span>
        <h2>Cuéntame tu caso y recibe una primera ruta de acción</h2>
        <p>
          Comparte tu país de origen, destino, objetivo migratorio y momento actual para entender qué camino
          conviene revisar primero
        </p>
        <ul>
          <li><strong>Correo:</strong> {siteConfig.email}</li>
          <li><strong>Teléfono:</strong> {siteConfig.phone}</li>
          <li><strong>Modalidad:</strong> {siteConfig.locationLabel}</li>
        </ul>
        <div class="contact-actions">
          <a class="btn btn-primary" href="/contacto/">Solicitar evaluación inicial</a>
        </div>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
    {JSON.stringify(faqSchema)}
  </script>
</Layout>
