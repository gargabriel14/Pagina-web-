---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import {
  consultationDeliverables,
  decisionPoints,
  faqItems,
  processSteps,
  services,
  siteConfig,
  siteImages,
  trustSignals,
} from "../data/site";

const siteUrl = Astro.site ?? new URL(siteConfig.url);
const faqSchema = {
  "@type": "FAQPage",
  "@id": new URL("/#faq", siteUrl).toString(),
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Asesoría migratoria internacional | Cristian Gutiérrez"
  description="Asesoría migratoria internacional para evaluar visas, residencia, permisos y movilidad con una estrategia clara antes de iniciar el proceso"
  preloadImage={{
    src: siteImages.hero,
    sizes: "(min-width: 1024px) 560px, calc(100vw - 32px)",
  }}
  structuredData={faqSchema}
>
  <div class="page-shell">
    <header class="hero hero-conversion" id="inicio">
      <div class="hero-copy">
        <span class="eyebrow">Movilidad internacional con criterio</span>
        <h1>Asesoría migratoria internacional para avanzar con una ruta clara</h1>
        <p>
          Cristian Gutiérrez te ayuda a evaluar opciones, anticipar riesgos y ordenar los próximos pasos antes
          de invertir tiempo y dinero en un proceso migratorio
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/contacto/">Evaluar mi caso</a>
          <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
        </div>

        <div class="hero-proof" aria-label="Señales de confianza">
          {trustSignals.map((signal) => (
            <div class="hero-stat">
              <strong>{signal.value}</strong>
              <span>{signal.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-visual">
        <ResponsiveImage
          src={siteImages.hero}
          alt="Asesor migratorio conversando con un cliente en su oficina"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="840"
          height="620"
          sizes="(min-width: 1024px) 560px, calc(100vw - 32px)"
        />
        <div class="visual-callout">
          <span>Primera evaluación</span>
          <strong>Origen, destino, objetivo y próximos pasos</strong>
        </div>
      </div>
    </header>

    <section class="section section-dark" id="servicios">
      <div class="section-header">
        <p class="eyebrow">Cómo puedo ayudarte</p>
        <h2>Una estrategia adaptada a tu objetivo migratorio</h2>
      </div>
      <div class="cards-grid">
        {services.map((service) => (
          <article class="service-card">
            <span class="service-icon"><Icon name={service.icon} /></span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Decisiones críticas</p>
        <h2>La consulta está pensada para responder lo que realmente cambia el resultado</h2>
      </div>
      <div class="decision-layout">
        <div class="decision-list">
          {decisionPoints.map((point) => (
            <div class="decision-item">
              <span><Icon name="check" /></span>
              <p>{point}</p>
            </div>
          ))}
        </div>
        <div class="decision-panel">
          <span class="eyebrow">Antes de avanzar</span>
          <h3>Evita avanzar con una ruta equivocada</h3>
          <p>
            Una decisión tomada con información incompleta puede consumir semanas, dinero y oportunidades
            que una evaluación temprana ayuda a proteger
          </p>
          <a class="btn btn-primary" href="/contacto/">Revisar mi caso</a>
        </div>
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Qué recibes</p>
        <h2>Sales de la consulta con una ruta accionable, no con dudas nuevas</h2>
      </div>
      <div class="feature-grid">
        {consultationDeliverables.map((item) => (
          <article class="feature-card">
            <span class="feature-icon"><Icon name={item.icon} /></span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-split">
      <div class="about-copy">
        <p class="eyebrow">Enfoque profesional</p>
        <h2>Orientación directa, sin promesas vacías ni pasos innecesarios</h2>
        <p>
          Cada caso parte de tu situación real, el país de origen, el destino y el momento del proceso para que
          entiendas qué conviene revisar primero
        </p>

        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <span class="feature-icon"><Icon name="check" /></span>
            <h3>Asesoría práctica</h3>
            <p>Escenarios, riesgos y pasos concretos explicados en lenguaje claro</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon"><Icon name="document" /></span>
            <h3>Documentación ordenada</h3>
            <p>Expedientes consistentes, completos y fáciles de revisar</p>
          </div>
        </div>
      </div>

      <div class="about-image">
        <ResponsiveImage
          src={siteImages.advisor}
          alt="Asesor migratorio preparando una evaluación internacional en su oficina"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
          sizes="(min-width: 1024px) 480px, calc(100vw - 32px)"
        />
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Método de trabajo</p>
        <h2>Un proceso diseñado para que sepas qué hacer después de cada conversación</h2>
      </div>
      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <span class="step-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2>Respuestas rápidas antes de agendar</h2>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="section section-contact" id="contacto">
      <div class="contact-card contact-card-wide">
        <span class="eyebrow">Siguiente paso</span>
        <h2>Cuéntame qué quieres lograr y revisemos por dónde empezar</h2>
        <p>
          Comparte tu país de origen, destino, objetivo y momento actual para preparar una primera lectura
          de tu situación
        </p>
        <ul>
          <li><strong>Correo:</strong> <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
          <li><strong>Teléfono:</strong> <a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></li>
          <li><strong>Modalidad:</strong> {siteConfig.locationLabel}</li>
        </ul>
        <div class="contact-actions">
          <a class="btn btn-primary" href="/contacto/">Evaluar mi caso</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
