---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import { caseTypes, processSteps, services, siteConfig, siteImages } from "../data/site";
---

<Layout
  title="Cristian Gutierrez | Asesoria Migratoria Global"
  description="Acompanamiento migratorio para personas, familias y empresas que buscan visas, residencia, permisos de trabajo y movilidad internacional."
>
  <div class="page-shell">
    <header class="hero" id="inicio">
      <div class="hero-copy">
        <span class="eyebrow">Movilidad internacional</span>
        <h1>Planifica tu proceso migratorio con una guia clara de principio a fin.</h1>
        <p>
          Acompano a profesionales, familias y equipos internacionales a ordenar requisitos,
          documentacion y siguientes pasos para avanzar con seguridad en distintos destinos.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/contacto/">Agenda tu consulta</a>
          <a class="btn btn-secondary" href="/servicios/">Ver servicios</a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <strong>Global</strong>
            <span>Procesos internacionales</span>
          </div>
          <div class="hero-stat">
            <strong>1:1</strong>
            <span>Perfil a medida</span>
          </div>
          <div class="hero-stat">
            <strong>360</strong>
            <span>Estrategia y documentos</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <img
          src={siteImages.hero}
          alt="Reunion de asesoria migratoria en una oficina profesional"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="840"
          height="620"
        />
      </div>
    </header>

    <section class="section section-dark" id="servicios">
      <div class="section-header">
        <p class="eyebrow">Servicios migratorios</p>
        <h2>Apoyo para visas, residencia, permisos y planes de movilidad.</h2>
      </div>
      <div class="cards-grid">
        {services.map((service) => (
          <article class="service-card">
            <span class="service-icon"><Icon name={service.icon} /></span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-split">
      <div class="about-copy">
        <p class="eyebrow">Acerca de mi</p>
        <h2>Cada caso empieza con una estrategia migratoria realista.</h2>
        <p>
          Trabajo con personas y companias para reducir incertidumbre, ordenar requisitos y convertir procesos
          complejos en una hoja de ruta comprensible.
        </p>

        <div class="feature-grid feature-grid-2">
          <div class="feature-card">
            <span class="feature-icon"><Icon name="check" /></span>
            <h3>Asesoria practica</h3>
            <p>Explico escenarios, riesgos y pasos concretos con lenguaje claro.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon"><Icon name="document" /></span>
            <h3>Documentacion ordenada</h3>
            <p>Ayudo a preparar expedientes consistentes, completos y faciles de revisar.</p>
          </div>
        </div>
      </div>

      <div class="about-image">
        <img
          src={siteImages.advisor}
          alt="Saludo profesional como referencia para fotografia del asesor"
          loading="lazy"
          decoding="async"
          width="720"
          height="540"
        />
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Por que elegir este servicio</p>
        <h2>Claridad, seguimiento y criterio para tomar mejores decisiones.</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <span class="feature-icon"><Icon name="globe" /></span>
          <h3>Proceso transparente</h3>
          <p>Identifico requisitos, tiempos estimados y puntos criticos antes de avanzar.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="passport" /></span>
          <h3>Estrategia por perfil</h3>
          <p>El plan se adapta al destino, objetivo migratorio, familia, empresa y documentacion disponible.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon"><Icon name="calendar" /></span>
          <h3>Acompanamiento continuo</h3>
          <p>Respondo dudas, reviso avances y ajusto el plan si cambian las condiciones del caso.</p>
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="section-header">
        <p class="eyebrow">Metodo de trabajo</p>
        <h2>Un proceso estructurado para avanzar con confianza.</h2>
      </div>
      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <span class="step-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-light">
      <div class="section-header">
        <p class="eyebrow">Casos tipo</p>
        <h2>Situaciones frecuentes donde una estrategia clara cambia el proceso.</h2>
      </div>
      <div class="testimonial-grid">
        {caseTypes.map((caseType) => (
          <article class="testimonial-card">
            <p>{caseType.description}</p>
            <strong>{caseType.title}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-split section-partners">
      <div class="partners-copy">
        <p class="eyebrow">Red internacional</p>
        <h2>Colaboracion con especialistas segun destino, perfil y tipo de tramite.</h2>
        <p>
          Esta seccion deja espacio para aliados, abogados locales, gestores, consultores fiscales y partners
          de integracion cuando el proyecto lo requiera.
        </p>
      </div>
      <div class="logo-grid">
        <div class="logo-item">Abogados locales</div>
        <div class="logo-item">Traductores</div>
        <div class="logo-item">Empresas</div>
        <div class="logo-item">Instituciones</div>
      </div>
    </section>

    <section class="section section-contact" id="contacto">
      <div class="contact-card">
        <span class="eyebrow">Contacto</span>
        <h2>Hablemos de tu plan migratorio.</h2>
        <p>Recibe una orientacion inicial y una ruta clara para tu situacion de trabajo, estudio, familia o empresa.</p>
        <ul>
          <li><strong>Email:</strong> {siteConfig.email}</li>
          <li><strong>Telefono:</strong> {siteConfig.phone}</li>
          <li><strong>Modalidad:</strong> {siteConfig.locationLabel}</li>
        </ul>
        <div class="contact-actions">
          <a class="btn btn-primary" href={`mailto:${siteConfig.email}`}>Enviar mensaje</a>
          <a class="btn btn-secondary" href="/sobre-nosotros/">Conocer al asesor</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
