---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Página no encontrada - Cristian Gutierrez" description="La página solicitada no existe. Regrese al inicio o visite nuestras páginas de servicios y contacto.">
  <div class="page-shell">
    <section class="section section-dark not-found-page">
      <div class="not-found-card">
        <p class="eyebrow">Error 404</p>
        <h1>Página no encontrada</h1>
        <p>La página que busca no está disponible. Use la navegación para volver al inicio o explorar nuestros servicios.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/">Inicio</a>
          <a class="btn btn-secondary" href="/servicios">Servicios</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
