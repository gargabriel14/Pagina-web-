---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada - Cristian Gutiérrez"
  description="La página solicitada no existe, regresa al inicio o visita nuestras páginas de servicios y contacto"
  noindex={true}
>
  <div class="page-shell">
    <section class="section section-dark not-found-page">
      <div class="not-found-card">
        <p class="eyebrow">Error 404</p>
        <h1>Página no encontrada</h1>
        <p>La página que buscas no está disponible, usa la navegación para volver al inicio o explorar servicios</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/">Inicio</a>
          <a class="btn btn-secondary" href="/servicios/">Servicios</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
