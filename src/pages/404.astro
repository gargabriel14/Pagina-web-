---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Pagina no encontrada - Cristian Gutierrez"
  description="La pagina solicitada no existe. Regresa al inicio o visita nuestras paginas de servicios y contacto."
  noindex={true}
>
  <div class="page-shell">
    <section class="section section-dark not-found-page">
      <div class="not-found-card">
        <p class="eyebrow">Error 404</p>
        <h1>Pagina no encontrada</h1>
        <p>La pagina que buscas no esta disponible. Usa la navegacion para volver al inicio o explorar servicios.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/">Inicio</a>
          <a class="btn btn-secondary" href="/servicios/">Servicios</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
