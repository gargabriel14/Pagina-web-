---
import "../styles/global.css";
import { ClientRouter, slide } from "astro:transitions";
import { siteConfig } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  preloadImage?: {
    src: string;
    sizes: string;
  };
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  imageAlt = siteConfig.ogImageAlt,
  preloadImage,
  structuredData,
  noindex = false,
} = Astro.props as Props;

const siteUrl = Astro.site ?? new URL(siteConfig.url);
const homeUrl = new URL("/", siteUrl).toString();
const normalizedPathname = Astro.url.pathname === "/" ? "/" : `${Astro.url.pathname.replace(/\/$/, "")}/`;
const pageUrl = new URL(normalizedPathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const businessImageUrl = new URL(siteConfig.ogImage, siteUrl).toString();
const logoUrl = new URL(siteConfig.logo, siteUrl).toString();
const currentYear = new Date().getFullYear();
const currentPath = normalizedPathname.replace(/\/$/, "") || "/";
const optimizedWidths = [480, 720, 1080, 1400];
const getImageBaseName = (src: string) => (src.split("/").pop() ?? "").replace(/\.[^.]+$/, "");
const getOptimizedSrcset = (src: string, format: "avif" | "webp") => {
  const baseName = getImageBaseName(src);
  return optimizedWidths
    .map((imageWidth) => `/images/optimized/${baseName}-${imageWidth}.${format} ${imageWidth}w`)
    .join(", ");
};
const preloadImageHref = preloadImage
  ? `/images/optimized/${getImageBaseName(preloadImage.src)}-720.avif`
  : undefined;
const preloadImageSrcset = preloadImage ? getOptimizedSrcset(preloadImage.src, "avif") : undefined;
const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/servicios/", label: "Servicios" },
  { href: "/sobre-nosotros/", label: "Enfoque" },
  { href: "/contacto/", label: "Contáctame", featured: true },
];
const isCurrent = (href: string) => {
  const normalizedHref = href.replace(/\/$/, "") || "/";
  return currentPath === normalizedHref;
};
const pageTransition = slide({ duration: "280ms" });
const websiteId = new URL("#website", homeUrl).toString();
const businessId = new URL("#business", homeUrl).toString();
const advisorId = new URL("#advisor", homeUrl).toString();
const webpageId = new URL("#webpage", pageUrl).toString();
const extraStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const structuredDataGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: homeUrl,
      name: siteConfig.name,
      description: siteConfig.description,
      inLanguage: siteConfig.language,
    },
    {
      "@type": "ProfessionalService",
      "@id": businessId,
      name: siteConfig.name,
      url: homeUrl,
      description: siteConfig.description,
      image: businessImageUrl,
      logo: logoUrl,
      areaServed: "Worldwide",
      serviceType: "Asesoría migratoria internacional",
      founder: {
        "@id": advisorId,
      },
      contactPoint: {
        "@type": "ContactPoint",
        email: siteConfig.email,
        telephone: siteConfig.phoneHref,
      },
    },
    {
      "@type": "Person",
      "@id": advisorId,
      name: siteConfig.name,
      jobTitle: "Asesor migratorio",
      url: homeUrl,
      worksFor: {
        "@id": businessId,
      },
    },
    {
      "@type": "WebPage",
      "@id": webpageId,
      url: pageUrl,
      name: title,
      description,
      inLanguage: siteConfig.language,
      primaryImageOfPage: imageUrl,
      isPartOf: {
        "@id": websiteId,
      },
    },
    ...extraStructuredData,
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1010" />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    {
      preloadImageHref && preloadImageSrcset && (
        <link
          rel="preload"
          as="image"
          href={preloadImageHref}
          type="image/avif"
          imagesrcset={preloadImageSrcset}
          imagesizes={preloadImage?.sizes}
          fetchpriority="high"
        />
      )
    }

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {
      !noindex && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredDataGraph)} />
      )
    }
    <ClientRouter fallback="animate" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <header class="header" transition:name="site-header" transition:animate="none">
      <nav class="navbar" aria-label="Navegación principal">
        <div class="nav-container">
          <a class="logo" href="/" aria-label={`${siteConfig.name} - Inicio`}>
            <img class="brand-mark" src={siteConfig.logo} alt="" width="40" height="40" />
            <span class="logo-text">Cristian <span class="logo-gold">Gutiérrez</span></span>
          </a>

          <ul class="nav-menu nav-menu-desktop">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={`nav-link${item.featured ? " btn btn-primary" : ""}`}
                    aria-current={isCurrent(item.href) ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <details class="nav-disclosure">
            <summary class="menu-toggle" aria-label="Abrir menú">
              <span></span>
              <span></span>
              <span></span>
            </summary>

            <ul class="nav-menu nav-menu-mobile">
              {
                navItems.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class={`nav-link${item.featured ? " btn btn-primary" : ""}`}
                      aria-current={isCurrent(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </details>
        </div>
      </nav>
    </header>

    <div class="page-stage" transition:name="page-content" transition:animate={pageTransition}>
      <main class="main-content" id="main-content">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-container">
          <div class="footer-grid footer-grid-main">
            <div class="footer-section footer-brand">
              <a class="footer-logo" href="/" aria-label={`${siteConfig.name} - Inicio`}>
                <img class="brand-mark" src={siteConfig.logo} alt="" width="40" height="40" loading="lazy" />
                <span class="footer-title">{siteConfig.name}</span>
              </a>
              <p>Asesoría migratoria internacional para personas, familias y equipos que necesitan avanzar con claridad</p>
            </div>

            <div class="footer-section">
              <h2 class="footer-subtitle">Navegación</h2>
              <ul class="footer-menu">
                <li><a href="/">Inicio</a></li>
                <li><a href="/servicios/">Servicios</a></li>
                <li><a href="/sobre-nosotros/">Enfoque</a></li>
                <li><a href="/contacto/">Contacto</a></li>
              </ul>
            </div>

            <div class="footer-section">
              <h2 class="footer-subtitle">Contacto</h2>
              <ul class="footer-contact">
                <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
                <li><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phone}</a></li>
                <li>{siteConfig.locationLabel}</li>
              </ul>
            </div>

            <div class="footer-section">
              <h2 class="footer-subtitle">Legal</h2>
              <ul class="footer-menu">
                <li><a href="/privacidad/">Política de privacidad</a></li>
                <li><a href="/terminos/">Términos y condiciones</a></li>
              </ul>
            </div>
          </div>

          <div class="footer-bottom">
            <p>&copy; {currentYear} {siteConfig.name} · Todos los derechos reservados</p>
          </div>
        </div>
      </footer>
    </div>

  </body>
</html>
